# Mrpbot 配置文件（示例）

bot:
  # 机器人显示名称
  name: "智能助手"
  # 被叫到这些名字也会触发“指向机器人”逻辑
  aliases: ["助手", "小助理"]
  # 日志级别 (DEBUG, INFO, WARNING, ERROR)
  log_level: "INFO"

persona:
  # 人设名：会尝试加载 config/characters/<name>.md
  name: "assistant"
  # 人设文件路径（可选；设置后优先于 name）
  # file: "config/characters/assistant.md"
  # 显式系统提示词（可选；优先级高于 file/name）
  # system_prompt: ""

channels:
  onebot:
    # 是否启用 OneBot 通道
    enabled: true
    # NapCat/OneBot WebSocket 地址
    ws_url: "ws://127.0.0.1:6199"
    # 访问令牌（建议走环境变量）
    access_token: "${QQ_ACCESS_TOKEN}"
    # 连接断开后的重连间隔（秒）
    reconnect_interval: 5

llm:
  # API Key（走环境变量更安全）
  api_key: "${DEEPSEEK_API_KEY}"
  # 兼容 OpenAI 协议的接口地址
  base_url: "https://api.deepseek.com"
  # 使用模型
  model: "deepseek-chat"
  # 单次请求超时（秒）
  timeout: 30
  # 请求失败最大重试次数
  max_retries: 3

features:
  chat:
    # 聊天功能开关
    enabled: true
    # 单次回复最大 token
    max_tokens: 1024
    # 随机性（越高越发散）
    temperature: 0.7

  group:
    # 群聊回复策略开关
    enabled: true
    # @机器人时是否必回
    reply_when_mentioned: true
    # 决策日志详细程度：off / concise / detailed
    decision_log_level: "concise"
    # 回复阈值（越低越活跃）
    reply_threshold: 50
    # 会话冷却（秒）
    cooldown: 12

    # 回复欲望模型调参（可选，不要重要）
    desire_tuning:
      # 初始欲望起点（私聊 / 群聊）
      base_private_desire: 34
      base_group_desire: 24
      # 每分钟自然衰减
      decay_per_minute: 1.6
      # 直接点名 / @机器人
      direct_attention_boost: 24
      # 明确提问 / 请求帮助
      question_boost: 14
      # 情绪 / 玩笑 / 感叹
      emotion_boost: 8
      # 带一点信息量的正常消息
      content_depth_bonus: 4
      # 群聊里轮到自己接话
      speaker_turn_bonus: 3.5
      # 群聊活跃度奖励
      activity_per_speaker: 1.8
      max_activity_bonus: 6.0
      # 机器人长时间没说话时的小幅补偿
      bot_quiet_threshold_seconds: 180
      bot_quiet_bonus: 3
      # 填充词 / 复读 / 近似复读惩罚
      filler_penalty: -10
      repetition_penalty: -8
      near_repeat_penalty: -4
      short_message_penalty: -6
      # 没有明显信号时的群聊环境热度
      ambient_group_interest: 2

    # 回复节奏控制
    reply_control:
      # 同一用户分段输入合并窗口（秒）
      merge_window_seconds: 7
      # 回看窗口：提取同一用户最近分段消息（秒）
      # 重要
      merge_lookback_seconds: 12
      # 最多合并几段
      merge_max_parts: 3
      # 非@场景最小回复间隔（秒），防止句句都回
      non_mention_min_interval_seconds: 60
      # 命中停口令后静默时长（秒）
      quiet_mode_seconds: 600
      # 停口令关键词，出现后进入静默
      stop_words: ["别回了", "别回复", "不要回", "先别说话", "停一下"]

    # 元 AI 去重（处理群聊里复杂话题回复）
    meta_ai:
      # 元AI裁决开关
      enabled: true
      # 同话题最小回复间隔（秒）
      topic_min_interval_seconds: 60
      # 裁决时读取的最近上下文条数
      max_context_messages: 12
      # decision=wait 时默认等待秒数
      default_wait_seconds: 12
      # wait/skip 最小置信度（低于此值回退 reply）
      min_confidence: 0.78
      # 重复话题相似度阈值（越高越不容易拦截）
      duplicate_similarity_threshold: 0.72

  memory:
    # 记忆系统开关
    enabled: true
    # 短期记忆条数上限
    short_term_size: 100
    # 自动保存间隔（秒）
    auto_save_interval: 300
    # 长期记忆目录
    dir: "memory"
    # 自动记忆目录
    auto_dir: "memory_auto"

  proactive:
    # 主动回复（默认关闭）
    enabled: false
